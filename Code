import time

class Process:
    def __init__(self, pid, burst_time):
        self.pid = pid
        self.burst_time = burst_time

def round_robin(processes, quantum):
    time_elapsed = 0

    while processes:
        process = processes.pop(0)

        if process.burst_time > quantum:
            print(f"Process {process.pid} running for {quantum} sec")
            time.sleep(1)
            process.burst_time -= quantum
            time_elapsed += quantum
            processes.append(process)
        else:
            print(f"Process {process.pid} finished execution")
            time.sleep(1)
            time_elapsed += process.burst_time

    print("All processes completed")

# Example processes
process_list = [
    Process(1, 5),
    Process(2, 3),
    Process(3, 8)
]

round_robin(process_list, 2)
